<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('partials/navbar_cliente') %>

  <main class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-6 text-gray-500 text-sm">
      <a href="/" class="hover:text-[#2B6398] transition-colors">Inicio</a>
      <span class="material-icons text-sm">chevron_right</span>
      <span class="text-gray-900 font-medium">Mi Perfil</span>
    </div>

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
      <h1 class="text-2xl font-bold text-gray-900">Información del Perfil</h1>
    </div>

    <!-- User Information -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-8">
      <div class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <span class="material-icons text-[#2B6398]">account_circle</span>
          Datos Personales
        </h2>
      </div>
      <div class="p-4 sm:p-6 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <span class="block text-sm font-medium text-gray-500 mb-1">Nombre de la Concesionaria</span>
          <span class="block text-base text-gray-900 font-medium">Suministros Industriales del Bajío</span>
        </div>
        <div>
          <span class="block text-sm font-medium text-gray-500 mb-1">Correo Electrónico</span>
          <span class="block text-base text-gray-900">usuario@ejemplo.com</span>
        </div>
      </div>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-4">Cuentas y Sucursales</h2>
    
    <div class="flex flex-col gap-6">
      
      <!-- Cuenta 1 -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col">
        <div class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap justify-between items-center gap-4">
          <div>
            <h3 class="text-lg font-bold text-[#2B6398] flex items-center gap-2">
              <span class="material-icons">business</span>
              Cuenta 1
            </h3>
            <p class="text-sm text-gray-600 mt-1">ID: CTA-1001 • Esta cuenta tiene acceso a las siguientes sucursales para envío.</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-1 rounded-full border border-green-200 flex items-center gap-1">
              <span class="w-1.5 h-1.5 bg-green-600 rounded-full"></span>
              Activa
            </span>
            <button class="bg-white border border-gray-300 text-gray-700 px-3 py-1.5 rounded-md text-sm font-medium shadow-sm hover:bg-gray-50 transition-colors opacity-50 cursor-not-allowed" disabled>
              Cuenta actual
            </button>
          </div>
        </div>
        
        <div class="p-4 sm:p-6">
          <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Sucursales Disponibles</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Sucursal 1 -->
            <div class="border border-gray-200 rounded-md p-4 hover:border-[#2B6398] hover:shadow-sm transition-all cursor-pointer bg-white group">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-[#007185] group-hover:text-[#2B6398]">store</span>
                <span class="font-medium text-gray-900 group-hover:text-[#2B6398]">Centro</span>
              </div>
              <p class="text-xs text-gray-500">Calle Principal #123, Zona Centro</p>
            </div>
            <!-- Sucursal 2 -->
            <div class="border border-gray-200 rounded-md p-4 hover:border-[#2B6398] hover:shadow-sm transition-all cursor-pointer bg-white group">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-[#007185] group-hover:text-[#2B6398]">store</span>
                <span class="font-medium text-gray-900 group-hover:text-[#2B6398]">Norte (Industrial)</span>
              </div>
              <p class="text-xs text-gray-500">Parque Industrial Norte, Lote 45</p>
            </div>
            <!-- Sucursal 3 -->
            <div class="border border-gray-200 rounded-md p-4 hover:border-[#2B6398] hover:shadow-sm transition-all cursor-pointer bg-white group">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-[#007185] group-hover:text-[#2B6398]">store</span>
                <span class="font-medium text-gray-900 group-hover:text-[#2B6398]">Sur</span>
              </div>
              <p class="text-xs text-gray-500">Av. Las Torres #789, Zona Sur</p>
            </div>
            <!-- Sucursal 4 -->
            <div class="border border-gray-200 rounded-md p-4 hover:border-[#2B6398] hover:shadow-sm transition-all cursor-pointer bg-white group">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-[#007185] group-hover:text-[#2B6398]">store</span>
                <span class="font-medium text-gray-900 group-hover:text-[#2B6398]">Este</span>
              </div>
              <p class="text-xs text-gray-500">Blvd. Oriente #456, Plaza Este</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Cuenta 2 -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col">
        <div class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap justify-between items-center gap-4">
          <div>
            <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
              <span class="material-icons text-gray-500">business</span>
              Cuenta 2
            </h3>
            <p class="text-sm text-gray-600 mt-1">ID: CTA-2055 • Cuenta para proyectos corporativos.</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-1 rounded-full border border-gray-300 flex items-center gap-1">
              <span class="w-1.5 h-1.5 bg-gray-500 rounded-full"></span>
              Inactiva
            </span>
            <button class="bg-[#2B6398] hover:bg-[#1e466b] text-white px-3 py-1.5 rounded-md text-sm font-medium shadow-sm transition-colors">
              Cambiar a esta cuenta
            </button>
          </div>
        </div>
        
        <div class="p-4 sm:p-6 opacity-75">
          <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Sucursales Disponibles</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Sucursal 1 -->
            <div class="border border-gray-200 rounded-md p-4 bg-gray-50">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-gray-400">store</span>
                <span class="font-medium text-gray-600">Oeste</span>
              </div>
              <p class="text-xs text-gray-500">Av. Poniente #101, Comercial</p>
            </div>
            <!-- Sucursal 2 -->
            <div class="border border-gray-200 rounded-md p-4 bg-gray-50">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-icons text-gray-400">store</span>
                <span class="font-medium text-gray-600">Centro Histórico</span>
              </div>
              <p class="text-xs text-gray-500">Calle Antigua #22, Centro</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>