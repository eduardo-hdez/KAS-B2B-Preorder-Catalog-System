<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

  <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Campañas</h1>
          <p class="text-sm text-gray-500 mt-1">Consulta campañas pasadas, la vigente y las programadas. Gestiona banners por campaña.</p>
        </div>
        <a href="/empleado/campanas/nueva" class="inline-flex items-center justify-center gap-2 bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-lg font-medium shadow-sm transition-colors w-full md:w-auto">
          <span class="material-icons text-sm">add_circle_outline</span>
          Crear nueva campaña
        </a>
      </div>

      
      <section class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-icons text-gray-500">history</span>
          <h2 class="text-lg font-semibold text-gray-900">Campañas pasadas</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% campanasPasadas.forEach(function (c) { %>
            <article class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 flex flex-col opacity-95">
              <div class="flex items-start justify-between gap-2 mb-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Finalizada</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-1"><%= c.nombre %></h3>
              <p class="text-xs text-gray-500 mb-4">ID: <span class="font-mono text-gray-700"><%= c.id %></span></p>
              <dl class="space-y-2 text-sm text-gray-600 mb-6 flex-grow">
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Inicio</dt>
                  <dd class="font-medium text-gray-900"><%= c.fechaInicio %></dd>
                </div>
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Fin</dt>
                  <dd class="font-medium text-gray-900"><%= c.fechaFin %></dd>
                </div>
              </dl>
              <a href="/empleado/campanas/<%= encodeURIComponent(c.id) %>/banners" class="mt-auto inline-flex items-center justify-center gap-2 w-full border border-gray-300 text-[#007185] hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                <span class="material-icons text-[18px]">image</span>
                Ver banners
              </a>
            </article>
          <% }); %>
        </div>
      </section>

      <!-- Campaña actual -->
      <section class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-icons text-[#007185]">campaign</span>
          <h2 class="text-lg font-semibold text-gray-900">Campaña actual</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% if (campanaActual && campanaActual.length) { %>
            <% campanaActual.forEach(function (c) { %>
              <article class="bg-white rounded-lg border border-[#007185]/30 shadow-sm p-6 flex flex-col ring-1 ring-[#007185]/20">
                <div class="flex items-start justify-between gap-2 mb-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800">En curso</span>
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-1"><%= c.nombre %></h3>
                <p class="text-xs text-gray-500 mb-4">ID: <span class="font-mono text-gray-700"><%= c.id %></span></p>
                <dl class="space-y-2 text-sm text-gray-600 mb-6 flex-grow">
                  <div class="flex justify-between gap-2">
                    <dt class="text-gray-500">Inicio</dt>
                    <dd class="font-medium text-gray-900"><%= c.fechaInicio %></dd>
                  </div>
                  <div class="flex justify-between gap-2">
                    <dt class="text-gray-500">Fin</dt>
                    <dd class="font-medium text-gray-900"><%= c.fechaFin %></dd>
                  </div>
                </dl>
                <a href="/empleado/campanas/<%= encodeURIComponent(c.id) %>/banners" class="mt-auto inline-flex items-center justify-center gap-2 w-full border border-[#007185] text-[#007185] hover:bg-teal-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                  <span class="material-icons text-[18px]">image</span>
                  Ver banners
                </a>
              </article>
            <% }); %>
          <% } else { %>
            <p class="text-sm text-gray-500 col-span-full">No hay campaña activa en este momento.</p>
          <% } %>
        </div>
      </section>

      <!-- Campañas programadas -->
      <section class="mb-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-icons text-blue-600">event_available</span>
          <h2 class="text-lg font-semibold text-gray-900">Campañas programadas</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% campanasProgramadas.forEach(function (c) { %>
            <article class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 flex flex-col">
              <div class="flex items-start justify-between gap-2 mb-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Programada</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-1"><%= c.nombre %></h3>
              <p class="text-xs text-gray-500 mb-4">ID: <span class="font-mono text-gray-700"><%= c.id %></span></p>
              <dl class="space-y-2 text-sm text-gray-600 mb-6 flex-grow">
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Inicio</dt>
                  <dd class="font-medium text-gray-900"><%= c.fechaInicio %></dd>
                </div>
                <div class="flex justify-between gap-2">
                  <dt class="text-gray-500">Fin</dt>
                  <dd class="font-medium text-gray-900"><%= c.fechaFin %></dd>
                </div>
              </dl>
              <a href="/empleado/campanas/<%= encodeURIComponent(c.id) %>/banners" class="mt-auto inline-flex items-center justify-center gap-2 w-full border border-gray-300 text-[#007185] hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                <span class="material-icons text-[18px]">image</span>
                Ver banners
              </a>
            </article>
          <% }); %>
        </div>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
