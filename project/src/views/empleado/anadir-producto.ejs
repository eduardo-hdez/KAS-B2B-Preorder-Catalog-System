<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">

        <!-- Encabezado de la página -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Añadir Producto</h1>
            <p class="text-sm text-gray-500 mt-1">Añade un nuevo producto a un catálogo.</p>
          </div>
        </div>
      </div>
      <% if (error) { %>
        <div id="modalError" tabindex="-1" aria-hidden="true"
          class="<%= error ? '' : 'hidden' %> fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
          <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
            <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
            <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al añadir el producto a la
              base de datos. Revisa los datos a ingresar del producto y por favor intenta de nuevo.</h3>
            <div class="flex flex-col sm:flex-row justify-center gap-3">
              <button id="btnModalError" type="button"
                class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
                Aceptar
              </button>
            </div>
          </div>
        </div>
        <% } %>
          <% if (success) { %>
            <div class="mb-4 rounded-md bg-green-100 border border-green-400 text-green-700 px-4 py-3">
              Producto añadido correctamente a la base de datos y catálogo correspondiente.
            </div>
            <% } %>
              <section id="formSection" class="w-full flex justify-center mt-2 px-4">
                <div id="registerContainer" class="w-full max-w-3xl">
                  <form id="forma" action="/empleado/gestion-productos/anadir-producto" method="POST"
                    class="bg-white p-6 md:p-8 rounded-lg border border-gray-200 shadow-sm">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                      <!-- Id Producto -->
                      <div>
                        <label for="idProducto" class="block text-sm font-medium text-gray-700 mb-1">Id
                          Producto:</label>
                        <input type="text" id="idProducto" name="idProducto"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                      <!-- Nombre -->
                      <div>
                        <label for="nombreProducto" class="block text-sm font-medium text-gray-700 mb-1">Nombre:</label>
                        <input type="text" id="nombreProducto" name="nombreProducto"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                    </div>

                    <!-- Descripcion -->
                    <div class="mb-6">
                      <label for="descripcion" class="block text-sm font-medium text-gray-700 mb-1">Descripción:</label>
                      <textarea id="descripcion" name="descripcion" rows="3"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                        required></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                      <!-- Precio -->
                      <div>
                        <label for="precio" class="block text-sm font-medium text-gray-700 mb-1">Precio (pesos):</label>
                        <div class="relative">
                          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="text-gray-500 sm:text-sm">$</span>
                          </div>
                          <input type="number" step="0.01" id="precio" name="precio"
                            class="w-full pl-7 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                            required />
                        </div>
                      </div>
                      <!-- Foto -->
                      <div>
                        <label for="foto" class="block text-sm font-medium text-gray-700 mb-1">Foto (link URL):</label>
                        <input type="url" id="foto" name="foto" placeholder="https://"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                      <!-- Peso -->
                      <div>
                        <label for="peso" class="block text-sm font-medium text-gray-700 mb-1">Peso (kg):</label>
                        <input type="number" step="0.01" id="peso" name="pesoUnidad"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                      <!-- Unidad de venta -->
                      <div>
                        <label for="unidadVenta" class="block text-sm font-medium text-gray-700 mb-1">Unidad de
                          venta:</label>
                        <input type="text" id="unidadVenta" name="unidadVenta" placeholder="Ej. Pieza, Caja"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                      <!-- id_campana (formulario) -->
                      <div>
                        <label for="idCampana" class="block text-sm font-medium text-gray-700 mb-1">Id de
                          catálogo/campaña:</label>
                        <input type="text" id="idCampana" name="idCampana"
                          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#007185] focus:border-transparent transition-shadow"
                          required />
                      </div>
                    </div>

                    <!-- Botones -->
                    <div id="toAccept"
                      class="flex flex-col sm:flex-row gap-3 justify-end pt-5 border-t border-gray-200">
                      <a href="/empleado/gestion-productos">
                        <button type="button" id="botonCancelarAnadido"
                          class="w-full sm:w-auto px-6 py-2 bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium rounded-md transition-colors shadow-sm">
                          Regresar a Gestión
                        </button>
                      </a>
                      <input type="submit" value="Registrar" id="botonRegistrar"
                        class="w-full sm:w-auto px-6 py-2 bg-[#007185] hover:bg-[#005d6e] text-white font-medium rounded-md transition-colors shadow-sm" />
                    </div>
                  </form>
                </div>
              </section>
    </main>
    <%- include('../partials/footer') %>
      <script>
        const modalError = document.getElementById('modalError');
        const btnModalError = document.getElementById('btnModalError');
        function ocultarModal() {
          modalError.classList.add('hidden');
        }
        btnModalError.addEventListener('click', ocultarModal);
        // Cerrar modal al hacer clic en el overlay (fuera de la caja blanca)
        modalError.addEventListener('click', (e) => {
          if (e.target === modalError) {
            ocultarModal();
          }
        });
      </script>
</body>

</html>