<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">

        <!-- Encabezado de la página -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Gestión de Productos</h1>
            <p class="text-sm text-gray-500 mt-1">Administra el inventario, añade nuevos productos o actualiza los
              existentes.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
            <button
              class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              <span class="material-icons text-sm">upload_file</span>
              Carga Masiva
            </button>
            <a href="/empleado/gestion-productos/anadir-producto"
              class="bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              Añadir Producto
            </a>
            <button type="button" id="btnAbrirConfirmacion"
              class="bg-white border border-gray-300 text-red-600 hover:bg-red-50 hover:border-red-200 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              <span class="material-icons text-sm">remove_circle_outline</span>
              Deshabilitar seleccionados
            </button>
          </div>
        </div>
        <% if (error) { %>
          <div id="modalErrorGestion" tabindex="-1" aria-hidden="true"
            class="<%= error ? '' : 'hidden' %> fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
            <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
              <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
              <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al recuperar los productos
                del catálogo actual de la
                base de datos. Por favor intenta más tarde.</h3>
              <div class="flex flex-col sm:flex-row justify-center gap-3">
                <a href="/empleado">
                  <button id="btnModalErrorGestion" type="button"
                    class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
                    Aceptar
                  </button>
                </a>
              </div>
            </div>
          </div>
          <% } %>
            <!-- Barra de Filtros -->
            <div
              class="bg-white p-4 rounded-lg border border-gray-200 mb-6 shadow-sm flex flex-col md:flex-row gap-4 justify-end items-center">
              <div class="flex gap-4 w-full md:w-auto">
                <select
                  class="w-full md:w-auto border border-gray-300 rounded-lg py-2 px-3 text-sm focus:ring-[#007185] focus:border-[#007185]">
                  <option value="">Todos los artículos</option>
                  <option value="rollos">Rollos</option>
                  <option value="kits">Kits</option>
                  <option value="pinturas">Pinturas</option>
                  <option value="vestimenta">Vestimenta</option>
                </select>
                <select
                  class="w-full md:w-auto border border-gray-300 rounded-lg py-2 px-3 text-sm focus:ring-[#007185] focus:border-[#007185]">
                  <option value="">Todas las categorías</option>
                  <option value="paraguas">Paraguas</option>
                  <option value="mochilas">Mochilas</option>
                  <option value="termos">Termos</option>
                  <option value="otros">Otros Accesorios</option>
                </select>
              </div>
            </div>

            <!-- Tabla de Productos -->
            <form action="/empleado/gestion-productos/deshabilitar" method="POST" id="form-deshabilitar">
              <div class="bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
                <div class="overflow-x-auto">
                  <table class="w-full text-left border-collapse">
                    <thead>
                      <tr class="bg-gray-50 border-b border-gray-200 text-sm text-gray-600">
                        <th class="p-4 font-semibold w-16 text-center">ID</th>
                        <th class="p-4 font-semibold">Producto</th>
                        <th class="p-4 font-semibold">Estado</th>
                        <th class="p-4 font-semibold">Artículo</th>
                        <th class="p-4 font-semibold">Unidad de venta</th>
                        <th class="p-4 font-semibold text-right">Precio</th>
                        <th class="p-4 font-semibold text-center">Acciones</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-sm text-gray-800">
                      <% if (!productos || productos.length===0) { %>
                        <tr>
                          <td colspan="6" class="p-4 text-center text-gray-600">
                            La campaña actual (seleccionada) no cuenta con productos registrados por el momento.
                          </td>
                        </tr>
                        <% } else { %>
                          <% productos.forEach((producto)=> { %>
                            <tr class="hover:bg-gray-50 transition-colors">
                              <td class="p-4 text-center text-gray-500 font-medium">
                                <%= producto.id_producto || 'N/A' %>
                              </td>
                              <td class="p-4">
                                <div class="flex items-center gap-3">
                                  <div
                                    class="w-12 h-12 bg-gray-100 rounded flex items-center justify-center flex-shrink-0 border border-gray-200">
                                    <img
                                      src="<%= producto.foto_producto || 'https://placehold.co/40x40/ffffff/cccccc?text=P' %>"
                                      alt="<%= producto.nombre_producto || 'Producto' %>"
                                      class="max-w-full max-h-full mix-blend-multiply p-1">
                                  </div>
                                  <div>
                                    <p class="font-medium text-gray-900 line-clamp-1">
                                      <%= producto.nombre_producto || producto.nombre || 'Producto sin nombre' %>
                                    </p>
                                    <p class="text-xs text-gray-500">ID: <%= producto.id_producto || 'N/A' %>
                                    </p>
                                  </div>
                                </div>
                              </td>
                              <td class="p-4">
                                <span
                                  class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                  <%= producto.habilitado ? 'Habilitado' : 'Deshabilitado' %>
                                </span>
                              </td>
                              <td class="p-4">
                                <span
                                  class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                  General
                                </span>
                              </td>
                              <td class="p-4 text-gray-500">
                                <%= producto.unidad_venta_producto || 'N/A' %>
                              </td>
                              <td class="p-4 text-right font-medium text-gray-900">$<%= Number(producto.precio_producto
                                  ?? 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                                  %>
                              </td>
                              <td class="p-4">
                                <div class="flex items-center justify-center gap-2">
                                  <button type="button"
                                    class="text-[#007185] hover:text-[#005d6e] hover:bg-teal-50 p-1.5 rounded-full transition-colors"
                                    title="Editar producto">
                                    <span class="material-icons text-[20px]">edit</span>
                                  </button>
                                  <button type="button"
                                    class="btn-eliminar-producto text-red-600 hover:text-red-700 hover:bg-red-50 p-1.5 rounded-full transition-colors"
                                    title="Eliminar producto">
                                    <span class="material-icons text-[20px]">delete</span>
                                  </button>
                                  <input type="checkbox" name="productosSeleccionados"
                                    value="<%= producto.id_producto %>"
                                    class="checkbox-producto w-4 h-4 ml-1 text-[#007185] bg-white border-gray-300 rounded focus:ring-[#007185] cursor-pointer">
                                </div>
                              </td>
                            </tr>
                            <% }) %>
                              <% } %>
                    </tbody>
                  </table>
                </div>
            </form>

            <!-- Paginación -->
            <div class="bg-gray-50 border-t border-gray-200 px-4 py-3 flex items-center justify-between sm:px-6">
              <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm text-gray-700">
                    Mostrando <span class="font-medium">1</span> a <span class="font-medium">
                      <%= productos ? productos.length : 0 %>
                    </span> de <span class="font-medium">
                      <%= productos ? productos.length : 0 %>
                    </span> resultados
                  </p>
                </div>
                <div>
                  <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <button
                      class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 cursor-not-allowed"
                      disabled>
                      <span class="sr-only">Anterior</span>
                      <span class="material-icons text-sm">chevron_left</span>
                    </button>
                    <button
                      class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                      1
                    </button>
                    <button
                      class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 cursor-not-allowed"
                      disabled>
                      <span class="sr-only">Siguiente</span>
                      <span class="material-icons text-sm">chevron_right</span>
                    </button>
                  </nav>
                </div>
              </div>
            </div>
      </div>
      </div>
    </main>

    <!-- Modal de confirmación -->
    <div id="modalConfirmacion" tabindex="-1" aria-hidden="true"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">¿Seguro que quieres deshabilitar los artículos seleccionados
          del catálogo activo?</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnCancelarModal" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Cancelar
          </button>
          <button id="btnConfirmarModal" type="button"
            class="order-1 sm:order-2 flex-1 text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Deshabilitar
          </button>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>
      <script>
        const modalErrorGestion = document.getElementById('modalErrorGestion');
        const btnModalErrorGestion = document.getElementById('btnModalErrorGestion');
        function ocultarModalGestion() {
          modalErrorGestion.classList.add('hidden');
        }
        btnModalErrorGestion.addEventListener('click', ocultarModalGestion);
        modalErrorGestion.addEventListener('click', (e) => {
          if (e.target === modalErrorGestion) {
            ocultarModalGestion();
          }
        });
        const modalConfirmacion = document.getElementById('modalConfirmacion');
        const btnCancelarModal = document.getElementById('btnCancelarModal');
        const btnConfirmarModal = document.getElementById('btnConfirmarModal');
        const formDeshabilitar = document.getElementById('form-deshabilitar');

        function mostrarModalConfirmacion() {
          modalConfirmacion.classList.remove('hidden');
        }

        function ocultarModalConfirmacion() {
          modalConfirmacion.classList.add('hidden');
        }

        btnCancelarModal.addEventListener('click', ocultarModalConfirmacion);

        btnConfirmarModal.addEventListener('click', () => {
          formDeshabilitar.submit();
        });

        // Cerrar modal al hacer clic en el overlay (fuera de la caja blanca)
        modalConfirmacion.addEventListener('click', (e) => {
          if (e.target === modalConfirmacion) {
            ocultarModalConfirmacion();
          }
        });

        function confirmarDeshabilitacion() {
          const seleccionados = document.querySelectorAll('.checkbox-producto:checked');

          if (seleccionados.length === 0) {
            alert('Selecciona al menos un producto.');
            return;
          }

          mostrarModalConfirmacion();
        }

        document.getElementById('btnAbrirConfirmacion').addEventListener('click', confirmarDeshabilitacion);

        document.querySelectorAll('.btn-eliminar-producto').forEach(btn => {
          btn.addEventListener('click', (e) => {
            // Desmarcar todos primero para asegurar que solo se elimine este
            document.querySelectorAll('.checkbox-producto').forEach(cb => cb.checked = false);

            // Encontrar el checkbox de la misma fila
            const row = e.target.closest('tr');
            if (row) {
              const checkbox = row.querySelector('.checkbox-producto');
              if (checkbox) {
                checkbox.checked = true;
              }
            }
            // Disparar confirmación
            confirmarDeshabilitacion();
          });
        });
      </script>
</body>

</html>