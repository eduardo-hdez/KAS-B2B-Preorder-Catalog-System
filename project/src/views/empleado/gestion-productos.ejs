<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

    <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">

        <!-- Encabezado de la página -->
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 mb-6">
          <div class="self-center">
            <h1 class="text-2xl font-bold text-gray-900">Gestión de Productos</h1>
            <p class="text-sm text-gray-500 mt-1">Administra el inventario, añade nuevos productos o actualiza los
              existentes.</p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 md:justify-end self-center w-full md:w-auto">
            <button
              class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              <span class="material-icons text-sm">upload_file</span>
              Carga Masiva
            </button>
            <a href="/empleado/gestion-productos/anadir-producto"
              class="bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              Añadir Producto
            </a>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 md:col-span-2 md:justify-end w-full md:w-auto">
            <button type="button" id="btnDeshabilitar"
              class="bg-white border border-gray-300 text-red-600 hover:bg-red-50 hover:border-red-200 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              <span class="material-icons text-sm">remove_circle_outline</span>
              Deshabilitar seleccionados
            </button>
            <button type="button" id="btnRehabilitar"
              class="bg-white border border-gray-300 text-green-600 hover:bg-green-50 hover:border-green-200 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center gap-2 w-full sm:w-auto justify-center">
              <span class="material-icons text-sm">add_circle_outline</span>
              Rehabilitar seleccionados
            </button>
          </div>
        </div>
      </div>
      <% if (errorRecuperacion) { %>
        <div id="modalErrorGestion" tabindex="-1" aria-hidden="true"
          class="<%= errorRecuperacion ? '' : 'hidden' %> fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
          <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
            <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
            <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al recuperar los productos
              del catálogo actual de la
              base de datos. Por favor intenta más tarde.</h3>
            <div class="flex flex-col sm:flex-row justify-center gap-3">
              <a href="/empleado">
                <button id="btnModalErrorGestion" type="button"
                  class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
                  Aceptar
                </button>
              </a>
            </div>
          </div>
        </div>
        <% } %>
          <% if (errorHabilitado) { %>
            <div id="modalErrorHabilitado" tabindex="-1" aria-hidden="true"
              class="<%= errorHabilitado ? '' : 'hidden' %> fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
              <div
                class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
                <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
                <h3 class="mb-6 text-lg font-medium text-gray-800">Lo siento, ocurrió un error al intentar cambiar el
                  estado de lo(s) producto(s) seleccionado(s). Por favor intenta de nuevo.</h3>
                <div class="flex flex-col sm:flex-row justify-center gap-3">
                  <button id="btnModalErrorHabilitado" type="button"
                    class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
                    Aceptar
                  </button>
                </div>
              </div>
            </div>
            <% } %>
              <% if (success==='deshabilitar' ) { %>
                <div class="mb-4 rounded-md bg-green-100 border border-green-400 text-green-700 px-4 py-3">
                  Producto(s) deshabilitado(s) del catálogo actual exitosamente.
                </div>
                <% } %>
                  <% if (success==='rehabilitar' ) { %>
                    <div class="mb-4 rounded-md bg-green-100 border border-green-400 text-green-700 px-4 py-3">
                      Producto(s) rehabilitado(s) del catálogo actual exitosamente.
                    </div>
                    <% } %>
                      <!-- Barra de Filtros y Búsqueda -->
                      <div
                        class="bg-white p-4 rounded-lg border border-gray-200 mb-6 shadow-sm flex flex-col md:flex-row gap-4 justify-between items-center">
                        
                        <!-- Búsqueda -->
                        <div class="w-full md:w-1/3 relative">
                          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-icons text-gray-400 text-sm">search</span>
                          </div>
                          <input type="text" id="busquedaProducto" placeholder="Buscar por nombre..."
                            class="w-full pl-10 pr-3 border border-gray-300 rounded-lg py-2 text-sm focus:ring-[#007185] focus:border-[#007185]">
                        </div>

                        <!-- Filtros -->
                        <div class="flex gap-4 w-full md:w-auto">
                          <select id="filtroEstado"
                            class="w-full md:w-auto border border-gray-300 rounded-lg py-2 px-3 text-sm focus:ring-[#007185] focus:border-[#007185]">
                            <option value="">Todos los estados</option>
                            <option value="habilitado">Habilitados</option>
                            <option value="deshabilitado">Deshabilitados</option>
                          </select>
                          <select id="filtroUnidad"
                            class="w-full md:w-auto border border-gray-300 rounded-lg py-2 px-3 text-sm focus:ring-[#007185] focus:border-[#007185]">
                            <option value="">Todas las unidades de venta</option>
                            <option value="caja">Caja</option>
                            <option value="cubeta">Cubeta</option>
                            <option value="rollo">Rollo</option>
                            <option value="kit">Kit</option>
                          </select>
                        </div>
                      </div>

                      <!-- Tabla de Productos -->
                      <form method="POST" id="form-habilitado">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
                          <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                              <thead>
                                <tr class="bg-gray-50 border-b border-gray-200 text-sm text-gray-600">
                                  <th class="p-4 font-semibold w-16 text-center">ID</th>
                                  <th class="p-4 font-semibold">Producto</th>
                                  <th class="p-4 font-semibold">Estado</th>
                                  <th class="p-4 font-semibold">Unidad de venta</th>
                                  <th class="p-4 font-semibold text-right">Precio</th>
                                  <th class="p-4 font-semibold text-center">Acciones</th>
                                </tr>
                              </thead>
                              <tbody class="divide-y divide-gray-200 text-sm text-gray-800">
                                <% if (!productos || productos.length===0) { %>
                                  <tr>
                                    <td colspan="6" class="p-4 text-center text-gray-600">
                                      La campaña actual (seleccionada) no cuenta con productos registrados por el
                                      momento.
                                    </td>
                                  </tr>
                                  <% } else { %>
                                    <% productos.forEach((producto)=> { %>
                                      <tr class="hover:bg-gray-50 transition-colors"
                                        data-estado="<%= producto.habilitado ? 'habilitado' : 'deshabilitado' %>"
                                        data-unidad="<%= producto.unidad_venta_producto || '' %>"
                                        data-nombre="<%= (producto.nombre_producto || producto.nombre || '').toLowerCase() %>">
                                        <td class="p-4 text-center text-gray-500 font-medium">
                                          <%= producto.id_producto || 'N/A' %>
                                        </td>
                                        <td class="p-4">
                                          <div class="flex items-center gap-3">
                                            <div
                                              class="w-12 h-12 bg-gray-100 rounded flex items-center justify-center flex-shrink-0 border border-gray-200">
                                              <img
                                                src="<%= producto.foto_producto || 'https://placehold.co/40x40/ffffff/cccccc?text=P' %>"
                                                alt="<%= producto.nombre_producto || 'Producto' %>"
                                                class="max-w-full max-h-full mix-blend-multiply p-1">
                                            </div>
                                            <div>
                                              <p class="font-medium text-gray-900 line-clamp-1">
                                                <%= producto.nombre_producto || producto.nombre || 'Producto sin nombre'
                                                  %>
                                              </p>
                                              <p class="text-xs text-gray-500">ID: <%= producto.id_producto || 'N/A' %>
                                              </p>
                                            </div>
                                          </div>
                                        </td>
                                        <td class="p-4">
                                          <% if (producto.habilitado) { %>
                                            <span
                                              class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 uppercase">
                                              Habilitado
                                            </span>
                                            <% } else { %>
                                              <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 uppercase">
                                                Deshabilitado
                                              </span>
                                              <% } %>
                                        </td>
                                        <td class="p-4 text-gray-500">
                                          <%= producto.unidad_venta_producto || 'N/A' %>
                                        </td>
                                        <td class="p-4 text-right font-medium text-gray-900">$<%=
                                            Number(producto.precio_producto ?? 0).toLocaleString('es-MX', {
                                            minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                        </td>
                                        <td class="p-4">
                                          <div class="flex items-center justify-center gap-2">
                                            <button type="button"
                                              class="text-[#007185] hover:text-[#005d6e] hover:bg-teal-50 p-1.5 rounded-full transition-colors"
                                              title="Editar producto">
                                              <span class="material-icons text-[20px]">edit</span>
                                            </button>
                                            <% if (producto.habilitado) { %>
                                              <button type="button"
                                                class="btn-deshabilitar-producto text-red-600 hover:text-red-700 hover:bg-red-50 p-1.5 rounded-full transition-colors"
                                                title="Deshabilitar producto">
                                                <span class="material-icons text-[20px]">visibility_off</span>
                                              </button>
                                              <input type="checkbox" name="productosDeshabilitar"
                                                value="<%= producto.id_producto %>"
                                                class="checkbox-deshabilitar w-4 h-4 ml-1 text-[#007185] bg-white border-gray-300 rounded focus:ring-[#007185] cursor-pointer">
                                              <% } else { %>
                                                <button type="button"
                                                  class="btn-rehabilitar-producto text-green-600 hover:text-green-700 hover:bg-green-50 p-1.5 rounded-full transition-colors"
                                                  title="Rehabilitar producto">
                                                  <span class="material-icons text-[20px]">visibility</span>
                                                </button>
                                                <input type="checkbox" name="productosRehabilitar"
                                                  value="<%= producto.id_producto %>"
                                                  class="checkbox-rehabilitar w-4 h-4 ml-1 text-[#007185] bg-white border-gray-300 rounded focus:ring-[#007185] cursor-pointer">
                                                <% } %>
                                          </div>
                                        </td>
                                      </tr>
                                      <% }) %>
                                        <% } %>
                              </tbody>
                            </table>
                          </div>
                      </form>

                      <!-- Paginación -->
                      <div
                        class="bg-gray-50 border-t border-gray-200 px-4 py-3 flex items-center justify-between sm:px-6">
                        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                          <div>
                            <p class="text-sm text-gray-700">
                              Mostrando <span class="font-medium">1</span> a <span class="font-medium">
                                <%= productos ? productos.length : 0 %>
                              </span> de <span class="font-medium">
                                <%= productos ? productos.length : 0 %>
                              </span> resultados
                            </p>
                          </div>
                          <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px"
                              aria-label="Pagination">
                              <button
                                class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 cursor-not-allowed"
                                disabled>
                                <span class="sr-only">Anterior</span>
                                <span class="material-icons text-sm">chevron_left</span>
                              </button>
                              <button
                                class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                                1
                              </button>
                              <button
                                class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 cursor-not-allowed"
                                disabled>
                                <span class="sr-only">Siguiente</span>
                                <span class="material-icons text-sm">chevron_right</span>
                              </button>
                            </nav>
                          </div>
                        </div>
                      </div>
                      </div>
                      </div>
    </main>

    <!-- Modal de confirmación para deshabilitar productos-->
    <div id="modalDeshabilitar" tabindex="-1" aria-hidden="true"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">¿Seguro que quieres deshabilitar los artículos seleccionados
          del catálogo activo?</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnCancelarDeshabilitar" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Cancelar
          </button>
          <button id="btnConfirmarDeshabilitar" type="button"
            class="order-1 sm:order-2 flex-1 text-white bg-red-600 hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Deshabilitar
          </button>
        </div>
      </div>
    </div>
    <!-- Modal de confirmación para rehabilitar productos-->
    <div id="modalRehabilitar" tabindex="-1" aria-hidden="true"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-green-600 text-5xl mb-4">check_circle_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">¿Seguro que quieres rehabilitar los artículos seleccionados
          para que aparezcan en el catálogo activo?</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnCancelarRehabilitar" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Cancelar
          </button>
          <button id="btnConfirmarRehabilitar" type="button"
            class="order-1 sm:order-2 flex-1 text-white bg-green-600 hover:bg-green-700 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Rehabilitar
          </button>
        </div>
      </div>
    </div>
    <!-- Modal informativo de no selección de productos para deshabilitar o rehabilitar-->
    <div id="modalNoSeleccion" tabindex="-1" aria-hidden="true"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity">
      <div class="relative w-full max-w-md bg-white rounded-lg shadow-xl p-6 text-center border border-gray-200">
        <span class="material-icons text-red-600 text-5xl mb-4">error_outline</span>
        <h3 class="mb-6 text-lg font-medium text-gray-800">Por favor selecciona al menos un producto al que se le pueda
          aplicar la acción seleccionada.</h3>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <button id="btnModalNoSeleccion" type="button"
            class="order-2 sm:order-1 flex-1 text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 focus:ring-4 focus:outline-none focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 transition-colors">
            Aceptar
          </button>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>
      <script>
        // Script de modal informativo de error en la recuperación de datos de los productos
        const modalErrorGestion = document.getElementById('modalErrorGestion');
        const btnModalErrorGestion = document.getElementById('btnModalErrorGestion');

        if (modalErrorGestion && btnModalErrorGestion) {
          function ocultarModalGestion() {
            modalErrorGestion.classList.add('hidden');
          }
          btnModalErrorGestion.addEventListener('click', ocultarModalGestion);
          modalErrorGestion.addEventListener('click', (e) => {
            if (e.target === modalErrorGestion) {
              ocultarModalGestion();
            }
          });
        }
        //Script de modal informativo de error en la modificación del estado de los productos (deshabilitar o rehabilitar)
        const modalErrorHabilitado = document.getElementById('modalErrorHabilitado');
        const btnModalErrorHabilitado = document.getElementById('btnModalErrorHabilitado');

        if (modalErrorHabilitado && btnModalErrorHabilitado) {
          function ocultarModalErrorHabilitado() {
            modalErrorHabilitado.classList.add('hidden');
          }
          btnModalErrorHabilitado.addEventListener('click', ocultarModalErrorHabilitado);
          modalErrorHabilitado.addEventListener('click', (e) => {
            if (e.target === modalErrorHabilitado) {
              ocultarModalErrorHabilitado();
            }
          });
        }
        //Script de modal de confirmación y envío para deshabilitar productos
        const modalDeshabilitar = document.getElementById('modalDeshabilitar');
        const btnCancelarDeshabilitar = document.getElementById('btnCancelarDeshabilitar');
        const btnConfirmarDeshabilitar = document.getElementById('btnConfirmarDeshabilitar');
        const formHabilitado = document.getElementById('form-habilitado');
        const modalNoSeleccion = document.getElementById('modalNoSeleccion');
        const btnModalNoSeleccion = document.getElementById('btnModalNoSeleccion');

        function mostrarModalDeshabilitar() {
          modalDeshabilitar.classList.remove('hidden');
        }

        function ocultarModalDeshabilitar() {
          modalDeshabilitar.classList.add('hidden');
        }

        function mostrarModalNoSeleccion() {
          modalNoSeleccion.classList.remove('hidden');
        }

        function ocultarModalNoSeleccion() {
          modalNoSeleccion.classList.add('hidden');
        }

        if (modalNoSeleccion && btnModalNoSeleccion) {
          btnModalNoSeleccion.addEventListener('click', ocultarModalNoSeleccion);
          modalNoSeleccion.addEventListener('click', (e) => {
            if (e.target === modalNoSeleccion) {
              ocultarModalNoSeleccion();
            }
          });
        }

        btnCancelarDeshabilitar.addEventListener('click', ocultarModalDeshabilitar);

        btnConfirmarDeshabilitar.addEventListener('click', () => {
          formHabilitado.action = "/empleado/gestion-productos/deshabilitar"
          formHabilitado.submit();
        });

        modalDeshabilitar.addEventListener('click', (e) => { // Cerrar modal al hacer clic en el overlay (fuera de la caja blanca)
          if (e.target === modalDeshabilitar) {
            ocultarModalDeshabilitar();
          }
        });

        function confirmarDeshabilitacion() {
          const seleccionados = document.querySelectorAll('.checkbox-deshabilitar:checked');

          if (seleccionados.length === 0) {
            mostrarModalNoSeleccion();
            return;
          }

          mostrarModalDeshabilitar();
        }

        document.getElementById('btnDeshabilitar').addEventListener('click', confirmarDeshabilitacion);

        document.querySelectorAll('.btn-deshabilitar-producto').forEach(btn => {
          btn.addEventListener('click', (e) => {
            document.querySelectorAll('.checkbox-deshabilitar').forEach(cb => cb.checked = false); // Desmarcar todos primero para asegurar que solo se elimine este

            const row = e.currentTarget.closest('tr'); // Encontrar el checkbox de la misma fila
            if (row) {
              const checkbox = row.querySelector('.checkbox-deshabilitar');
              if (checkbox) {
                checkbox.checked = true;
              }
            }

            confirmarDeshabilitacion(); // Disparar confirmación
          });
        });
        //Script de modal de confirmación y envío para rehabilitar productos
        const modalRehabilitar = document.getElementById('modalRehabilitar');
        const btnCancelarRehabilitar = document.getElementById('btnCancelarRehabilitar');
        const btnConfirmarRehabilitar = document.getElementById('btnConfirmarRehabilitar');

        function mostrarModalRehabilitar() {
          modalRehabilitar.classList.remove('hidden');
        }

        function ocultarModalRehabilitar() {
          modalRehabilitar.classList.add('hidden');
        }

        btnCancelarRehabilitar.addEventListener('click', ocultarModalRehabilitar);

        btnConfirmarRehabilitar.addEventListener('click', () => {
          formHabilitado.action = "/empleado/gestion-productos/rehabilitar"
          formHabilitado.submit();
        });
        modalRehabilitar.addEventListener('click', (e) => {
          if (e.target === modalRehabilitar) {
            ocultarModalRehabilitar();
          }
        });

        function confirmarRehabilitacion() {
          const seleccionados = document.querySelectorAll('.checkbox-rehabilitar:checked');

          if (seleccionados.length === 0) {
            mostrarModalNoSeleccion();
            return;
          }

          mostrarModalRehabilitar();
        }

        document.getElementById('btnRehabilitar').addEventListener('click', confirmarRehabilitacion);

        document.querySelectorAll('.btn-rehabilitar-producto').forEach(btn => {
          btn.addEventListener('click', (e) => {
            document.querySelectorAll('.checkbox-rehabilitar').forEach(cb => cb.checked = false);
            const row = e.currentTarget.closest('tr');
            if (row) {
              const checkbox = row.querySelector('.checkbox-rehabilitar');
              if (checkbox) {
                checkbox.checked = true;
              }
            }
            confirmarRehabilitacion();
          });
        });
        //Script de los filtros
        const busquedaProducto = document.getElementById('busquedaProducto');
        const filtroEstado = document.getElementById('filtroEstado');
        const filtroUnidad = document.getElementById('filtroUnidad');
        const filas = document.querySelectorAll('tbody tr');

        function aplicarFiltros() {
          const busqueda = busquedaProducto.value.trim().toLowerCase();
          const estado = filtroEstado.value;
          const unidad = filtroUnidad.value.trim().toLowerCase();

          filas.forEach(fila => {
            // Saltar las filas que no tengan los atributos de datos (como la fila de "sin productos")
            if (!fila.hasAttribute('data-estado')) return;

            const nombreProducto = fila.dataset.nombre || '';
            const cumpleBusqueda = !busqueda || nombreProducto.includes(busqueda);

            const cumpleEstado = !estado || fila.dataset.estado === estado;
            const filaUnidad = fila.dataset.unidad ? fila.dataset.unidad.toLowerCase() : '';
            const cumpleUnidad = !unidad || filaUnidad.startsWith(unidad);

            fila.style.display = cumpleBusqueda && cumpleEstado && cumpleUnidad ? '' : 'none';
          });
        }

        busquedaProducto.addEventListener('input', aplicarFiltros);
        filtroEstado.addEventListener('change', aplicarFiltros);
        filtroUnidad.addEventListener('change', aplicarFiltros);
      </script>
</body>

</html>