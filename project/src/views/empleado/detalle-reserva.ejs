<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-empleado') %>

  <main class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">

    <div class="mb-6 flex justify-between items-center flex-wrap gap-4">
      <h1 class="text-2xl font-bold text-gray-900">Detalles de la reserva <span class="text-gray-500 font-normal text-lg ml-2">#RES-10502</span></h1>
      <span class="bg-green-100 text-green-800 px-3 py-1.5 rounded-full text-sm font-medium flex items-center gap-1 border border-green-200 shadow-sm">
        <span class="material-icons text-[18px]">check_circle</span>
        Confirmada
      </span>
    </div>

    <div class="flex flex-col gap-6">
      <!-- Order Summary Card -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div class="flex flex-wrap gap-6 sm:gap-10 text-sm text-gray-600">
            <div class="flex flex-col">
              <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Reserva realizada</span>
              <span class="text-gray-900 font-medium">5 de Marzo de 2026</span>
            </div>
            <div class="flex flex-col">
              <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Cliente / Concesionaria</span>
              <span class="text-[#007185] font-medium hover:underline cursor-pointer">Auto Grupo S.A. de C.V.</span>
              <span class="text-xs text-gray-500">Taller de Pintura</span>
            </div>
            <div class="flex flex-col">
              <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Sucursal asignada</span>
              <span class="text-gray-900 font-medium">Centro</span>
            </div>
          </div>
        </div>

        <div class="p-4 sm:p-6 grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Información del Cliente -->
          <div class="flex flex-col gap-2">
            <h3 class="font-bold text-gray-900 text-base mb-1">Información del cliente</h3>
            <p class="text-sm text-gray-700">
              <span class="font-medium">Atención: Juan Pérez</span><br>
              Av. Tecnológico 123<br>
              Col. Solidaridad, C.P. 20190<br>
              Aguascalientes, Ags.<br>
              México
            </p>
            <p class="text-sm text-gray-700 mt-2">
              <span class="font-medium">Teléfono:</span> (449) 123-4567<br>
              <span class="font-medium">Email:</span> compras@autogrupo.com
            </p>
          </div>

          <!-- Detalles logísticos -->
          <div class="flex flex-col gap-2">
            <h3 class="font-bold text-gray-900 text-base mb-1">Detalles logísticos</h3>
            <p class="text-sm text-gray-700">
              <span class="font-medium">Sucursal origen:</span> Centro<br>
              <span class="font-medium">Peso total estimado:</span> 14.5 kg
            </p>
          </div>

          <!-- Resumen financiero -->
          <div class="flex flex-col gap-2 bg-gray-50 p-4 rounded-md border border-gray-100">
            <h3 class="font-bold text-gray-900 text-base mb-2">Resumen financiero</h3>
            <div class="flex justify-between text-sm text-gray-600 mb-1">
              <span>Productos (Subtotal):</span>
              <span>$4,481.03</span>
            </div>
            <div class="flex justify-between text-sm text-gray-600 mb-1">
              <span>Costo de envío:</span>
              <span>$0.00</span>
            </div>
            <div class="flex justify-between text-sm text-gray-600 mb-2 pb-2 border-b border-gray-200">
              <span>IVA (16%):</span>
              <span>$716.97</span>
            </div>
            <div class="flex justify-between text-base font-bold text-gray-900">
              <span>Total a cobrar:</span>
              <span>$5,198.00</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Products List -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-200 flex justify-between items-center">
          <h2 class="text-lg font-bold text-gray-900">Productos reservados</h2>
          <span class="text-sm text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">2 artículos en total</span>
        </div>
        
        <div class="p-4 sm:p-6 flex flex-col gap-6">
          <!-- Producto 1 -->
          <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
            <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md border border-gray-200 p-2 flex items-center justify-center">
              <img src="https://placehold.co/400x400/ffffff/cccccc?text=DC3000" alt="DeltronNXT DC3000" class="max-h-full max-w-full object-contain mix-blend-multiply">
            </div>
            <div class="flex flex-col flex-grow w-full">
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 w-full">
                <div>
                  <a href="#" class="text-base sm:text-lg font-medium text-[#007185] hover:text-[#005d6e] hover:underline block leading-tight">DeltronNXT DC3000</a>
                  
                  <!-- VALORACIÓN CONSISTENTE CON CATÁLOGO -->
                  <div class="flex items-center text-sm mt-1.5 mb-1.5">
                    <div class="flex text-[#FFA41C]">
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star_half</span>
                    </div>
                    <span class="text-[#007185] ml-2 text-xs hover:underline cursor-pointer">1,245</span>
                  </div>

                  <div class="text-sm text-gray-500 space-y-1">
                    <p>Unidad de venta: <span class="text-gray-900 font-medium">3.75 Litros</span></p>
                    <p>Cantidad solicitada: <span class="text-gray-900 font-medium">1</span></p>
                  </div>
                </div>
                <div class="text-left sm:text-right mt-2 sm:mt-0">
                  <div class="text-xs text-gray-500 mb-1">Precio unitario: $2,399.00</div>
                  <span class="text-lg font-bold text-gray-900">$2,399.00</span>
                </div>
              </div>
              <div class="flex flex-wrap gap-3 items-center mt-4">
                <button class="bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-md text-sm font-medium shadow-sm transition-colors flex items-center gap-1.5">
                  <span class="material-icons text-[18px]">visibility</span>
                  Ver artículo
                </button>
              </div>
            </div>
          </div>
          
          <hr class="border-gray-100">

          <!-- Producto 2 -->
          <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
            <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md border border-gray-200 p-2 flex items-center justify-center">
              <img src="https://placehold.co/400x400/ffffff/cccccc?text=Speedhide" alt="Speedhide Max Prime" class="max-h-full max-w-full object-contain mix-blend-multiply">
            </div>
            <div class="flex flex-col flex-grow w-full">
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 w-full">
                <div>
                  <a href="#" class="text-base sm:text-lg font-medium text-[#007185] hover:text-[#005d6e] hover:underline block leading-tight">Speedhide Max Prime 6-0000 (Interior)</a>
                  
                  <!-- VALORACIÓN CONSISTENTE CON CATÁLOGO -->
                  <div class="flex items-center text-sm mt-1.5 mb-1.5">
                    <div class="flex text-[#FFA41C]">
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star</span>
                      <span class="material-icons" style="font-size: 16px;">star_border</span>
                    </div>
                    <span class="text-[#007185] ml-2 text-xs hover:underline cursor-pointer">87</span>
                  </div>

                  <div class="text-sm text-gray-500 space-y-1">
                    <p>Unidad de venta: <span class="text-gray-900 font-medium">Pieza</span></p>
                    <p>Cantidad solicitada: <span class="text-gray-900 font-medium">1</span></p>
                  </div>
                </div>
                <div class="text-left sm:text-right mt-2 sm:mt-0">
                  <div class="text-xs text-gray-500 mb-1">Precio unitario: $2,799.00</div>
                  <span class="text-lg font-bold text-gray-900">$2,799.00</span>
                </div>
              </div>
              <div class="flex flex-wrap gap-3 items-center mt-4">
                <button class="bg-[#007185] hover:bg-[#005d6e] text-white px-4 py-2 rounded-md text-sm font-medium shadow-sm transition-colors flex items-center gap-1.5">
                  <span class="material-icons text-[18px]">visibility</span>
                  Ver artículo
                </button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
