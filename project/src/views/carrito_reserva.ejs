<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('partials/navbar_cliente') %>

  <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <div class="flex items-center gap-2 mb-6 text-gray-500 text-sm">
      <a href="/" class="hover:text-[#2B6398] transition-colors">Inicio</a>
      <span class="material-icons text-sm">chevron_right</span>
      <span class="text-gray-900 font-medium">Carrito de Reserva</span>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-8">Mi Carrito de Reserva</h1>
    
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Lista de Productos -->
      <div class="flex-grow flex flex-col gap-4">
        
        <!-- Producto 1 -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-6 flex flex-col sm:flex-row items-center sm:items-start gap-6 relative">
          <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md p-2 flex items-center justify-center">
            <img src="https://placehold.co/400x400/ffffff/cccccc?text=DC3000" alt="DeltronNXT DC3000" class="max-h-full max-w-full object-contain">
          </div>
          
          <div class="flex-grow w-full flex flex-col h-full justify-between">
            <div class="flex justify-between items-start w-full gap-4">
              <div>
                <h3 class="font-bold text-lg text-gray-900 leading-tight">DeltronNXT DC3000</h3>
                <p class="text-sm text-gray-500 mt-1">Unidad de venta: <span class="font-medium text-gray-700">3.75 Litros</span></p>
              </div>
              <span class="text-xl font-bold text-gray-900 text-right">$4,798.00</span>
            </div>
            
            <div class="flex flex-col sm:flex-row justify-between items-center w-full mt-4 sm:mt-auto gap-4">
              <div class="flex items-center gap-4 w-full sm:w-auto">
                <div class="flex items-center border border-gray-300 rounded-md h-10">
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-l-md material-icons text-sm">remove</button>
                  <input type="text" value="2" class="w-12 h-full text-center border-x border-gray-300 font-medium text-gray-900 outline-none" readonly>
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-r-md material-icons text-sm">add</button>
                </div>
                <span class="text-sm text-gray-500">$2,399.00 c/u</span>
              </div>
              
              <div class="flex items-center gap-3 w-full sm:w-auto justify-end border-t sm:border-t-0 pt-4 sm:pt-0 border-gray-100">
                <button class="text-[#2B6398] hover:text-[#1e466b] text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-blue-50">
                  <span class="material-icons text-base">visibility</span>
                  Ver artículo
                </button>
                <button class="text-red-500 hover:text-red-700 text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-red-50">
                  <span class="material-icons text-base">delete_outline</span>
                  Eliminar
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Producto 2 -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-6 flex flex-col sm:flex-row items-center sm:items-start gap-6 relative">
          <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md p-2 flex items-center justify-center">
            <img src="https://placehold.co/400x400/ffffff/cccccc?text=Turbo+Finish" alt="Turbo Finish" class="max-h-full max-w-full object-contain">
          </div>
          
          <div class="flex-grow w-full flex flex-col h-full justify-between">
            <div class="flex justify-between items-start w-full gap-4">
              <div>
                <h3 class="font-bold text-lg text-gray-900 leading-tight">Turbo Finish - Barniz de poliuretano</h3>
                <p class="text-sm text-gray-500 mt-1">Unidad de venta: <span class="font-medium text-gray-700">0.788 Litros</span></p>
              </div>
              <span class="text-xl font-bold text-gray-900 text-right">$4,830.00</span>
            </div>
            
            <div class="flex flex-col sm:flex-row justify-between items-center w-full mt-4 sm:mt-auto gap-4">
              <div class="flex items-center gap-4 w-full sm:w-auto">
                <div class="flex items-center border border-gray-300 rounded-md h-10">
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-l-md material-icons text-sm">remove</button>
                  <input type="text" value="1" class="w-12 h-full text-center border-x border-gray-300 font-medium text-gray-900 outline-none" readonly>
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-r-md material-icons text-sm">add</button>
                </div>
                <span class="text-sm text-gray-500">$4,830.00 c/u</span>
              </div>
              
              <div class="flex items-center gap-3 w-full sm:w-auto justify-end border-t sm:border-t-0 pt-4 sm:pt-0 border-gray-100">
                <button class="text-[#2B6398] hover:text-[#1e466b] text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-blue-50">
                  <span class="material-icons text-base">visibility</span>
                  Ver artículo
                </button>
                <button class="text-red-500 hover:text-red-700 text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-red-50">
                  <span class="material-icons text-base">delete_outline</span>
                  Eliminar
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Producto 3 -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-6 flex flex-col sm:flex-row items-center sm:items-start gap-6 relative">
          <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md p-2 flex items-center justify-center">
            <img src="https://placehold.co/400x400/ffffff/cccccc?text=Top+Cars+DMD1684" alt="Top Cars DMD1684" class="max-h-full max-w-full object-contain">
          </div>
          
          <div class="flex-grow w-full flex flex-col h-full justify-between">
            <div class="flex justify-between items-start w-full gap-4">
              <div>
                <h3 class="font-bold text-lg text-gray-900 leading-tight">Top Cars DMD1684 Base Color</h3>
                <p class="text-sm text-gray-500 mt-1">Unidad de venta: <span class="font-medium text-gray-700">Pieza</span></p>
              </div>
              <span class="text-xl font-bold text-gray-900 text-right">$850.00</span>
            </div>
            
            <div class="flex flex-col sm:flex-row justify-between items-center w-full mt-4 sm:mt-auto gap-4">
              <div class="flex items-center gap-4 w-full sm:w-auto">
                <div class="flex items-center border border-gray-300 rounded-md h-10">
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-l-md material-icons text-sm">remove</button>
                  <input type="text" value="1" class="w-12 h-full text-center border-x border-gray-300 font-medium text-gray-900 outline-none" readonly>
                  <button class="px-3 h-full text-gray-600 hover:bg-gray-100 transition-colors rounded-r-md material-icons text-sm">add</button>
                </div>
                <span class="text-sm text-gray-500">$850.00 c/u</span>
              </div>
              
              <div class="flex items-center gap-3 w-full sm:w-auto justify-end border-t sm:border-t-0 pt-4 sm:pt-0 border-gray-100">
                <button class="text-[#2B6398] hover:text-[#1e466b] text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-blue-50">
                  <span class="material-icons text-base">visibility</span>
                  Ver artículo
                </button>
                <button class="text-red-500 hover:text-red-700 text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-red-50">
                  <span class="material-icons text-base">delete_outline</span>
                  Eliminar
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>
      
      <!-- Resumen -->
      <div class="w-full lg:w-[380px] flex-shrink-0">
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 sticky top-6">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Resumen de la Reserva</h2>
          
          <div class="flex justify-between items-center mb-4 text-[15px] text-gray-600">
            <span>Subtotal (4 productos)</span>
            <span class="font-medium text-gray-900">$10,478.00</span>
          </div>
          
          <div class="flex justify-between items-center mb-4 text-[15px] text-gray-600">
            <span>IVA (16%)</span>
            <span class="font-medium text-gray-900">$1,676.48</span>
          </div>

          <div class="border-t border-gray-200 my-4 pt-4">
            <div class="flex justify-between items-center mb-2">
              <span class="text-lg font-bold text-gray-900">Total a pagar</span>
              <span class="text-2xl font-black text-gray-900">$12,154.48</span>
            </div>
          </div>
          
          <div class="mt-8 mb-6">
            <label for="sucursal" class="block text-sm font-bold text-gray-700 mb-2">
              Seleccionar Sucursal para Enviar <span class="text-red-500">*</span>
            </label>
            <div class="relative">
              <select id="sucursal" name="sucursal" class="w-full appearance-none border border-gray-300 rounded-md shadow-sm focus:border-[#2B6398] focus:ring focus:ring-[#2B6398] focus:ring-opacity-20 outline-none py-3 pl-4 pr-10 text-gray-700 bg-white transition-shadow" required>
                <option value="" disabled selected>Elige una sucursal...</option>
                <option value="centro">Sucursal Centro</option>
                <option value="norte">Sucursal Norte (Industrial)</option>
                <option value="sur">Sucursal Sur</option>
                <option value="este">Sucursal Este</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
                <span class="material-icons">expand_more</span>
              </div>
            </div>
          </div>
          
          <button class="w-full bg-[#2B6398] hover:bg-[#1e466b] text-white font-bold py-3.5 px-4 rounded-md shadow-md transition-colors duration-200 flex justify-center items-center gap-2">
            <span class="material-icons">check_circle</span>
            Confirmar Reserva
          </button>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>