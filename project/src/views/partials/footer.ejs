        Recargar página
      </button>
    </div>
  </div>
  <script>
    const url = new URL(window.location.href);
    if (url.searchParams.get('invalidToken') === '1') {
      document.getElementById('modalInvalidToken').classList.remove('hidden');
      url.searchParams.delete('invalidToken');
      window.history.replaceState({}, document.title, url.pathname + url.search);
    }
  </script>
