<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-cliente') %>

  <main class="w-full flex flex-col items-center pb-16 flex-grow bg-white">
  <!-- Banner principal -->
  <div class="w-full max-w-7xl mx-auto mt-6 px-4 sm:px-6 lg:px-8">
    <div class="w-full overflow-hidden">
      <!-- Reemplazar src con la imagen real del banner -->
      <img src="https://placehold.co/1200x250/000000/ffffff?text=WE+ARE+26+BANNER" alt="Banner Preventa" class="w-full h-auto object-cover md:rounded-lg">
    </div>
  </div>
  <!-- Contador -->
  <div class="w-full text-center py-6 text-gray-800 font-medium text-sm md:text-base">
    Tiempo de preventa restante: 4 días | 3 horas | 45 minutos | 32 segundos
  </div>

  <!-- Contenedor Principal (Filtros + Grid de Productos) -->
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row gap-6">
    
    <!-- Sidebar de Filtros -->
    <aside class="w-full md:w-64 flex-shrink-0">
      <div class="bg-white p-5 rounded-lg border border-gray-200 sticky top-4">
        <h2 class="text-lg font-bold mb-4 text-gray-900 border-b pb-2">Filtros</h2>
        
        <!-- Artículos -->
        <div class="mb-6">
          <h3 class="font-semibold text-gray-800 mb-3">Artículos</h3>
          <div class="space-y-2">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Rollos</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Kits</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Pinturas</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Vestimenta</span>
            </label>
          </div>
        </div>

        <!-- Categorías -->
        <div>
          <h3 class="font-semibold text-gray-800 mb-3">Categorías</h3>
          <div class="space-y-2">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Paraguas</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Mochilas</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Termos</span>
            </label>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#007185] focus:ring-[#007185]">
              <span class="ml-2 text-sm text-gray-700 hover:text-[#007185]">Otros Accesorios</span>
            </label>
          </div>
        </div>
      </div>
    </aside>

    <!-- Grid de Productos -->
    <div class="flex-grow">
      <% if (errorCatalogo) { %>
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
          <%= errorCatalogo %>
        </div>
      <% } %>

      <% if (!productos || productos.length === 0) { %>
        <div class="rounded-lg border border-gray-200 bg-white p-8 text-center text-gray-600">
          No hay productos disponibles por el momento.
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% productos.forEach((producto) => { %>
            <div class="flex flex-col h-full bg-white border border-gray-200 rounded-lg p-3 hover:shadow-lg transition-shadow">
              <div class="relative w-full aspect-square bg-gray-50 rounded-md mb-3 flex items-center justify-center p-4">
                <img
                  src="<%= producto.foto_producto || 'https://placehold.co/400x400/ffffff/cccccc?text=Sin+imagen' %>"
                  alt="<%= producto.nombre_producto || 'Producto sin nombre' %>"
                  class="max-h-full max-w-full object-contain mix-blend-multiply"
                >
              </div>
              <div class="flex flex-col flex-grow">
                <a href="/cliente/detalle-producto" class="text-base text-[#007185] hover:text-[#2B6398] hover:underline cursor-pointer line-clamp-2 leading-tight mb-1 font-medium block">
                  <%= producto.nombre || 'Producto sin nombre' %>
                </a>

                <p class="text-sm text-gray-600 mb-2 line-clamp-2">
                  <%= producto.descripcion || 'Sin descripcion disponible.' %>
                </p>

                <div class="mt-auto">
                  <div class="flex items-end gap-2 mb-3 text-gray-900">
                    <span class="text-2xl font-semibold">
                      $<%= Number(producto.precio || 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </span>
                    <span class="text-xs text-gray-500">
                      <%= producto.unidad_venta || '' %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</main>

  <%- include('../partials/footer') %>
</body>
</html>