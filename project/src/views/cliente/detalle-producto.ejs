<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-cliente') %>

  <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <% if (errorDetalle) { %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
        <%= errorDetalle %>
      </div>
      <p class="text-center">
        <a href="/cliente/catalogo" class="text-[#007185] hover:text-[#2B6398] font-medium underline">Volver al catálogo</a>
      </p>
    <% } else if (producto) { %>
      <% const nombre = producto.nombre_producto || 'Producto'; %>
      <% const descripcion = producto.descripcion_producto || ''; %>
      <% const precio = Number(producto.precio_producto ?? 0); %>
      <% const unidad = producto.unidad_venta_producto || ''; %>
      <% const foto = producto.foto_producto || 'https://placehold.co/600x600/ffffff/cccccc?text=Sin+imagen'; %>
      <% const pesoUnidad = producto.peso_unidad_producto != null && producto.peso_unidad_producto !== '' ? producto.peso_unidad_producto : null; %>

      <nav class="flex items-center text-sm text-gray-500 mb-6 flex-wrap" aria-label="Migas de pan">
        <a href="/cliente" class="hover:text-[#007185] transition-colors">Inicio</a>
        <span class="material-icons text-sm mx-1" aria-hidden="true">chevron_right</span>
        <a href="/cliente/catalogo" class="hover:text-[#007185] transition-colors">Catálogo</a>
        <span class="material-icons text-sm mx-1" aria-hidden="true">chevron_right</span>
        <span class="text-gray-900 font-medium"><%= nombre %></span>
      </nav>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6 lg:p-10 items-start">
          <div class="flex justify-center items-center bg-gray-50 rounded-lg p-6 border border-gray-100 h-full max-h-[450px]">
            <img src="<%= foto %>" alt="<%= nombre %>" class="max-w-full max-h-[320px] object-contain mix-blend-multiply rounded-md">
          </div>

          <div class="flex flex-col">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4 leading-tight"><%= nombre %></h1>

            <div class="border-t border-b border-gray-200 py-4 mb-6">
              <div class="flex items-end gap-2 text-gray-900">
                <span class="text-sm font-medium">$</span>
                <span class="text-4xl font-semibold leading-none"><%= precio.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
              </div>
              <% if (unidad) { %>
                <p class="text-sm text-gray-500 mt-2">Unidad de venta: <%= unidad %></p>
              <% } %>
              <p class="text-sm text-gray-500 mt-1">Precio sin IVA</p>
            </div>

            <% if (unidad) { %>
              <div class="mb-6">
                <span class="block text-sm font-medium text-gray-700 mb-2">Unidad de venta</span>
                <div class="inline-flex items-center border-2 border-[#007185] bg-blue-50 text-[#007185] rounded-md px-4 py-2 text-sm font-medium">
                  <%= unidad %><% if (pesoUnidad) { %> (<%= pesoUnidad %>)<% } %>
                </div>
              </div>
            <% } %>

            <div class="mb-6">
              <span class="block text-sm font-medium text-gray-700 mb-2">Cantidad</span>
              <div class="flex items-center w-32 border border-gray-300 rounded-md shadow-sm opacity-60 pointer-events-none" aria-hidden="true">
                <span class="w-10 h-10 flex justify-center items-center text-gray-600 rounded-l-md"><span class="material-icons text-sm">remove</span></span>
                <span class="w-12 h-10 flex items-center justify-center border-x border-gray-300 text-gray-900 text-sm">1</span>
                <span class="w-10 h-10 flex justify-center items-center text-gray-600 rounded-r-md"><span class="material-icons text-sm">add</span></span>
              </div>
              <p class="text-xs text-gray-500 mt-2">La selección de cantidad estará disponible cuando el carrito esté conectado.</p>
            </div>

            <div class="flex flex-col gap-3">
              <button type="button" disabled class="w-full bg-gray-300 border border-gray-400 rounded-full py-3 px-6 text-gray-600 font-medium cursor-not-allowed flex justify-center items-center gap-2 text-lg">
                <span class="material-icons">shopping_cart</span>
                Agregar al carrito
              </button>
            </div>
          </div>
        </div>
      </div>

      <% if (descripcion) { %>
        <div class="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 p-6 lg:p-10">
          <h2 class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">Descripción del producto</h2>
          <div class="prose max-w-none text-gray-700">
            <p class="whitespace-pre-wrap"><%= descripcion %></p>
          </div>
        </div>
      <% } %>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
