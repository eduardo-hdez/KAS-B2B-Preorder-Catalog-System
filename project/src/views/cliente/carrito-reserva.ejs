<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-cliente') %>

  <main class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <div class="flex items-center gap-2 mb-6 text-gray-500 text-sm">
      <a href="/cliente" class="hover:text-[#2B6398] transition-colors">Inicio</a>
      <span class="material-icons text-sm">chevron_right</span>
      <span class="text-gray-900 font-medium">Carrito de Reserva</span>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-8">Mi Carrito de Reserva</h1>

    <% if (errorCarrito) { %>
      <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
        <%= errorCarrito %>
      </div>
    <% } else { %>
      <%
        const items = Array.isArray(carrito?.productos_seleccionados) ? carrito.productos_seleccionados : [];
        const subtotal = items.reduce((acc, ps) => acc + Number(ps.producto?.precio_producto ?? 0) * ps.cantidad, 0);
        const iva = subtotal * 0.16;
        const total = subtotal + iva;
        const totalItems = items.reduce((acc, ps) => acc + ps.cantidad, 0);
      %>

      <% if (items.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-24 text-center">
          <span class="material-icons text-6xl text-gray-300 mb-4">shopping_cart</span>
          <h2 class="text-xl font-semibold text-gray-500 mb-2">Tu carrito está vacío</h2>
          <p class="text-gray-400 mb-6">Agrega productos desde el catálogo para comenzar tu reserva.</p>
          <a href="/cliente/catalogo" class="bg-[#2B6398] hover:bg-[#1e466b] text-white font-medium py-2.5 px-6 rounded-md transition-colors">
            Ir al catálogo
          </a>
        </div>
      <% } else { %>
        <div class="flex flex-col lg:flex-row lg:items-start gap-8">
          <!-- Lista de Productos -->
          <div class="flex-grow flex flex-col gap-4 min-w-0">
            <% items.forEach(ps => { %>
              <%
                const p = ps.producto;
                const precioUnitario = Number(p?.precio_producto ?? 0);
                const nombre = p?.nombre_producto ?? 'Producto';
                const unidad = p?.unidad_venta_producto ?? '';
                const foto = p?.foto_producto || 'https://placehold.co/400x400/ffffff/cccccc?text=Sin+imagen';
                const idProducto = p?.id_producto;
              %>
              <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-6 flex flex-col sm:flex-row gap-4 sm:gap-6">
                <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-gray-50 rounded-md p-2 flex items-center justify-center mx-auto sm:mx-0">
                  <img src="<%= foto %>" alt="<%= nombre %>" class="max-h-full max-w-full object-contain mix-blend-multiply">
                </div>

                <div class="flex-1 min-w-0 flex flex-col gap-4">
                  <div class="flex flex-row justify-between items-start gap-3 w-full">
                    <div class="min-w-0 flex-1">
                      <h3 class="font-bold text-lg text-gray-900 leading-tight break-words"><%= nombre %></h3>
                      <% if (unidad) { %>
                        <p class="text-sm text-gray-500 mt-1">Unidad de venta: <span class="font-medium text-gray-700"><%= unidad %></span></p>
                      <% } %>
                    </div>
                    <span class="text-xl font-bold text-gray-900 text-right flex-shrink-0 tabular-nums">
                      $<%= (precioUnitario * ps.cantidad).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                    </span>
                  </div>

                  <div class="flex flex-col sm:flex-row sm:flex-nowrap gap-3 pt-3 border-t border-gray-100 sm:items-center sm:justify-between">
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-500">
                      <span class="whitespace-nowrap">
                        $<%= precioUnitario.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> c/u
                      </span>
                      <% if (idProducto) { %>
                        <span class="text-gray-300 hidden sm:inline" aria-hidden="true">·</span>
                        <div class="inline-flex items-center gap-0 rounded-md border border-gray-200 bg-gray-50 flex-shrink-0">
                          <form method="POST" action="/cliente/carrito/actualizar/<%= idProducto %>" class="inline-flex m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="accion" value="-">
                            <button type="submit"
                              class="p-1.5 rounded-l-md text-gray-600 hover:bg-gray-200 hover:text-gray-900 transition-colors"
                              title="Disminuir cantidad"
                              aria-label="Disminuir cantidad">
                              <span class="material-icons text-lg leading-none">remove</span>
                            </button>
                          </form>
                          <span class="min-w-[2rem] text-center font-medium text-gray-800 tabular-nums px-1"><%= ps.cantidad %></span>
                          <form method="POST" action="/cliente/carrito/actualizar/<%= idProducto %>" class="inline-flex m-0">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="accion" value="+">
                            <button type="submit"
                              class="p-1.5 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-gray-900 transition-colors"
                              title="Aumentar cantidad"
                              aria-label="Aumentar cantidad">
                              <span class="material-icons text-lg leading-none">add</span>
                            </button>
                          </form>
                        </div>
                      <% } else { %>
                        <span>· Cantidad: <%= ps.cantidad %></span>
                      <% } %>
                    </div>

                    <div class="flex items-center gap-3 justify-end sm:justify-end sm:flex-shrink-0">
                      <% if (idProducto) { %>
                        <form method="POST" action="/cliente/carrito/eliminar" class="inline-flex m-0">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="id_producto" value="<%= idProducto %>">
                          <button type="submit" class="text-red-600 hover:text-red-800 hover:bg-red-50 p-2 rounded-md transition-colors flex items-center justify-center" title="Quitar del carrito" aria-label="Quitar del carrito">
                            <span class="material-icons text-xl">delete_outline</span>
                          </button>
                        </form>
                      <% } %>
                      <a href="/cliente/detalle-producto/<%= idProducto %>" class="text-[#2B6398] hover:text-[#1e466b] text-sm font-medium flex items-center gap-1 transition-colors px-2 py-1 rounded hover:bg-blue-50 whitespace-nowrap">
                        <span class="material-icons text-base">visibility</span>
                        Ver artículo
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>

          <!-- Resumen -->
          <div class="w-full lg:w-[380px] flex-shrink-0 lg:sticky lg:top-6 lg:self-start">
            <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6">
              <h2 class="text-xl font-bold text-gray-900 mb-6">Resumen de la Reserva</h2>

              <div class="flex justify-between items-center mb-4 text-[15px] text-gray-600">
                <span>Subtotal (<%= totalItems %> <%= totalItems === 1 ? 'producto' : 'productos' %>)</span>
                <span class="font-medium text-gray-900">$<%= subtotal.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
              </div>

              <div class="flex justify-between items-center mb-4 text-[15px] text-gray-600">
                <span>IVA (16%)</span>
                <span class="font-medium text-gray-900">$<%= iva.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
              </div>

              <div class="border-t border-gray-200 my-4 pt-4">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-lg font-bold text-gray-900">Total a pagar</span>
                  <span class="text-2xl font-black text-gray-900">$<%= total.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                </div>
              </div>

              <form method="POST" action="/cliente/reserva/confirmar">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mt-8 mb-6">
                  <label for="sucursal" class="block text-sm font-bold text-gray-700 mb-2">
                    Seleccionar Sucursal para Enviar <span class="text-red-500">*</span>
                  </label>
                  <div class="relative">
                    <select id="sucursal" name="id_sucursal" class="w-full appearance-none border border-gray-300 rounded-md shadow-sm focus:border-[#2B6398] focus:ring focus:ring-[#2B6398] focus:ring-opacity-20 outline-none py-3 pl-4 pr-10 text-gray-700 bg-white transition-shadow" required>
                      <option value="" disabled selected>Elige una sucursal...</option>
                      <% sucursales.forEach(s => { %>
                        <option value="<%= s.id_sucursal %>"><%= s.nombre_sucursal %></option>
                      <% }); %>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
                      <span class="material-icons">expand_more</span>
                    </div>
                  </div>
                </div>

                <button type="submit" class="w-full bg-[#2B6398] hover:bg-[#1e466b] text-white font-bold py-3.5 px-4 rounded-md shadow-md transition-colors duration-200 flex justify-center items-center gap-2">
                  <span class="material-icons">check_circle</span>
                  Confirmar Reserva
                </button>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
