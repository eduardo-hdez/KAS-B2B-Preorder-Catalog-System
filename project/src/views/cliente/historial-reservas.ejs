<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
  <%- include('../partials/navbar-cliente') %>

  <main class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
    <div class="flex items-center gap-2 mb-6 text-gray-500 text-sm">
      <a href="/" class="hover:text-[#2B6398] transition-colors">Inicio</a>
      <span class="material-icons text-sm">chevron_right</span>
      <span class="text-gray-900 font-medium">Historial de Reservas</span>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Mis Reservas</h1>

    <% if (successMessage) { %>
      <div class="mb-6 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
        <%= successMessage %>
      </div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <%= errorMessage %>
      </div>
    <% } %>

    <% if (!reservas || reservas.length === 0) { %>
      <div class="rounded-lg border border-gray-200 bg-white p-6 text-gray-600">
        No tienes reservas registradas.
      </div>
    <% } %>

    <div class="flex flex-col gap-6">
      <% (reservas || []).forEach((reserva) => { %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col">
          <div class="bg-gray-100 px-4 sm:px-6 py-4 border-b border-gray-200 flex flex-wrap md:flex-nowrap justify-between items-start gap-4">
            <div class="flex flex-wrap gap-6 sm:gap-10 text-sm text-gray-600">
              <div class="flex flex-col">
                <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Reserva realizada</span>
                <span class="text-gray-900"><%= new Date(reserva.fechaReserva).toLocaleString('es-MX') %></span>
              </div>
              <div class="flex flex-col">
                <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Total</span>
                <span class="text-gray-900 font-medium">$<%= reserva.total.toFixed(2) %></span>
              </div>
              <div class="flex flex-col">
                <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Sucursal</span>
                <span class="text-gray-900"><%= reserva.sucursal %></span>
              </div>
              <div class="flex flex-col">
                <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Peso Total</span>
                <span class="text-gray-900"><%= reserva.pesoTotal.toFixed(2) %> kg</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end text-sm w-full md:w-auto">
              <span class="uppercase text-[11px] font-bold text-gray-500 tracking-wider mb-1">Pedido #</span>
              <span class="text-gray-900 font-medium"><%= reserva.folio %></span>
            </div>
          </div>

          <div class="p-4 sm:p-6">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-6 gap-4 border-b border-gray-100 pb-6">
              <div>
                <h3 class="text-lg font-bold <%= reserva.estadoReserva ? 'text-gray-900' : 'text-red-700' %> flex items-center gap-2">
                  <span class="material-icons <%= reserva.estadoReserva ? 'text-green-600' : 'text-red-600' %>"><%= reserva.estadoReserva ? 'check_circle' : 'cancel' %></span>
                  <%= reserva.estadoTexto %>
                </h3>
                <% if (reserva.estadoReserva && reserva.puedeCancelar) { %>
                  <p class="text-sm text-orange-600 font-medium mt-2 items-center gap-1.5 bg-orange-50 px-3 py-1.5 rounded-md inline-flex border border-orange-100">
                    <span class="material-icons text-[18px]">schedule</span>
                    Tiempo restante: <strong><%= reserva.minutosRestantesFormato %></strong>
                  </p>
                <% } else if (reserva.estadoReserva) { %>
                  <p class="text-sm text-red-600 font-medium mt-2 flex items-center gap-1.5">
                    <span class="material-icons text-[18px]">lock</span>
                    Plazo de cancelación expirado
                  </p>
                <% } else { %>
                  <p class="text-sm text-gray-500 mt-2 flex items-center gap-1.5">
                    <span class="material-icons text-[18px]">calendar_today</span>
                    Cancelada el <%= reserva.fechaCancelacion ? new Date(reserva.fechaCancelacion).toLocaleString('es-MX') : 'N/D' %>
                  </p>
                <% } %>
              </div>
              <% if (reserva.estadoReserva && reserva.puedeCancelar) { %>
                <form method="POST" action="/cliente/reserva/<%= reserva.folio %>/cancelar" onsubmit="return confirm('¿Está seguro de que desea cancelar esta reserva? Esta acción no se puede deshacer.');">
                  <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-red-50 border border-red-300 rounded-md shadow-sm text-sm font-medium text-red-700 hover:bg-red-100 hover:border-red-400 transition-colors flex items-center justify-center gap-2">
                    <span class="material-icons text-[18px]">delete_outline</span>
                    Cancelar Reserva
                  </button>
                </form>
              <% } %>
            </div>

            <div class="flex flex-col gap-6">
              <% reserva.productos.forEach((producto, idx) => { %>
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                  <div class="w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 bg-white rounded-md border border-gray-200 p-2 flex items-center justify-center">
                    <img src="<%= producto.foto %>" alt="<%= producto.nombre %>" class="max-h-full max-w-full object-contain">
                  </div>
                  <div class="flex flex-col flex-grow">
                    <span class="text-base font-medium text-[#2B6398]"><%= producto.nombre %></span>
                    <span class="text-sm text-gray-500 mt-1">Unidad de venta: <%= producto.unidad %> - Cantidad: <%= producto.cantidad %></span>
                  </div>
                </div>
                <% if (idx < reserva.productos.length - 1) { %>
                  <hr class="border-gray-100">
                <% } %>
              <% }) %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    // Verificar parámetros de éxito/error y mostrar notificación
    document.addEventListener('DOMContentLoaded', function() {
      const params = new URLSearchParams(window.location.search);
      
      if (params.has('success')) {
        // Remover el parámetro de la URL sin recarga
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    });
  </script>
</body>
</html>